        "ticket": {
          "number": "INC-1063",
          "table": "incident",
          "state": "New",
          "severity": "2",
          "configuration_item": "product-catalog-service",
          "caller_id": "alex_kovalenko_dev",
          "short_description": "Cache TTL bug causing stale product data",
          "description": "I've identified a critical bug in the product-catalog-service caching logic. The Redis keys are being set with TTL: -1 (infinite/no expiry) instead of the configured 1-hour expiration.\n\nThis is causing product data to never refresh from the database. Any price or inventory updates made in the CMS remain stale indefinitely until manual cache flush.\n\nLogs confirm: 'INFO [Cache] Key metadata: TTL: -1 (No Expiry)'\n\nThis is a code-level bug that needs a patch, but in the meantime can you flush the cache to get current prices live?",
          "category": "Software"
        }
      },
      "ground_truth": {
        "summary": "Agent should confirm the code bug diagnosis. The cache flush will provide immediate relief but escalation to engineering is needed for permanent fix.",
        "verification_outcome": {
          "severity_check": "2",
          "scope_check": "reject",
          "incident_check": true,
          "verifiable": true,
          "claim_accuracy": "accurate",
          "requires_clarification": false
        },
        "correct_assignment_group": "Catalog_Engineering",
        "ticket_outcome": {
          "tool": "ticket-escalate",
          "args": {
            "agent_identity": "agent_707",
            "ticket_number": "INC-1063",
            "assignment_group": "Catalog_Engineering",
            "escalation_reason": "Confirmed application logic bug: product-catalog-service setting cache keys with TTL: -1 instead of configured 1h expiration. This causes indefinite stale data. Code fix required. Escalating to Catalog Engineering for patch development."
          }
        },
        "root_cause": "Application Logic Error (Missing Cache TTL)",
        "action_solution": null,
        "final_action": {
          "tool": "service-flush-cache",
          "args": {
            "agent_identity": "agent_707",
            "service_name": "product-catalog-service"
          }
        }
