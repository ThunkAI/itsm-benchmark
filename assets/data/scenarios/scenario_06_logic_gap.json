          "state": "New",
          "severity": "2",
          "configuration_item": "product-catalog-service",
          "caller_id": "sarah_jenkins_sales",
          "short_description": "The website says the iPhone is $500 but the cart says $800!",
          "description": "I'm on a call with a customer. The product page shows the iPhone 15 at $500 (the Black Friday price), but when they add it to the cart, it changes to $800.\n\nCustomers are angry and accusing us of bait-and-switch. Is the database out of sync?",
          "category": "Data Integrity"
        }
      },
      "ground_truth": {
        "summary": "The agent should identify that the issue is not infrastructure-related (metrics are green). Logs indicate Redis keys have no expiration (TTL: -1), causing stale data to persist. The agent must escalate to the engineering team responsible for the catalog code. Ideal mitigation would be to flush the cache to force fresh data load.",
        "verification_outcome": {
          "severity_check": "2",
          "scope_check": "reject",
          "incident_check": true,
          "verifiable": true,
          "claim_accuracy": "accurate",
          "requires_clarification": false
        },
        "correct_assignment_group": "Catalog_Engineering",
        "ticket_outcome": {
